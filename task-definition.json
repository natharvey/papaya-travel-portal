{
  "family": "papaya",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::095523580645:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "papaya-api",
      "image": "095523580645.dkr.ecr.us-east-1.amazonaws.com/papaya-api:latest",
      "portMappings": [{"containerPort": 8000}],
      "environment": [
        {"name": "DATABASE_URL", "value": "postgresql://papaya:papaya_secret@papaya-db.c230y8k047wv.us-east-1.rds.amazonaws.com:5432/postgres"},
        {"name": "JWT_SECRET", "value": "0cc951eff077acfd1ca7cc0adac6b8b08c431fcbed9b502429e2571974f4af50"},
        {"name": "ADMIN_PASSWORD", "value": "admin123"},
        {"name": "SEED_ON_STARTUP", "value": "true"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/papaya",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "api"
        }
      }
    },
    {
      "name": "papaya-web",
      "image": "095523580645.dkr.ecr.us-east-1.amazonaws.com/papaya-web:latest",
      "portMappings": [{"containerPort": 80}],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/papaya",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ]
}
